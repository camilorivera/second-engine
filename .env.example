# Postgres
POSTGRES_DB=secondengine
POSTGRES_USER=secondengine
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://secondengine:changeme@postgres:5432/secondengine

# Strava — register at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=        # populated by: python setup/auth.py strava

# Withings — register at https://developer.withings.com/
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_REFRESH_TOKEN=      # populated by: python setup/auth.py withings

# Optional overrides
MAX_HR_OVERRIDE=              # leave blank to use rolling 30-day observed peak
SYNC_INTERVAL_HOURS=1
ANALYTICS_INTERVAL_HOURS=6

# Grafana
GF_SECURITY_ADMIN_PASSWORD=changeme

# pgAdmin (optional --profile debug)
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=changeme
