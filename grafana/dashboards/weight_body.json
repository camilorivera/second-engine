{
  "uid": "second-engine-weight",
  "title": "Weight & Body Composition",
  "tags": ["second-engine"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "1h",
  "time": { "from": "now-1y", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Current Weight (kg)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "rawSql": "SELECT weight_kg AS value FROM body_metrics WHERE weight_kg IS NOT NULL ORDER BY measured_at DESC LIMIT 1",
        "format": "table",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none" },
      "fieldConfig": { "defaults": { "unit": "kg", "decimals": 1, "displayName": "Current Weight" } }
    },
    {
      "id": 2,
      "title": "Body Fat %",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "rawSql": "SELECT body_fat_pct AS value FROM body_metrics WHERE body_fat_pct IS NOT NULL ORDER BY measured_at DESC LIMIT 1",
        "format": "table",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "displayName": "Body Fat %" } }
    },
    {
      "id": 3,
      "title": "BMI",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "rawSql": "SELECT ROUND(bmi::numeric, 1) AS value FROM body_metrics WHERE bmi IS NOT NULL ORDER BY measured_at DESC LIMIT 1",
        "format": "table",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none" },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1, "displayName": "BMI" } }
    },
    {
      "id": 4,
      "title": "Weight Lost (total)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "rawSql": "SELECT ROUND((MAX(weight_kg) - MIN(weight_kg))::numeric, 1) AS value FROM body_metrics WHERE weight_kg IS NOT NULL",
        "format": "table",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none" },
      "fieldConfig": { "defaults": { "unit": "kg", "decimals": 1, "displayName": "Total Lost" } }
    },
    {
      "id": 5,
      "title": "Resting HR (latest)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "rawSql": "SELECT resting_hr_bpm AS value FROM resting_hr_daily ORDER BY date DESC LIMIT 1",
        "format": "table",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none" },
      "fieldConfig": { "defaults": { "unit": "bpm", "displayName": "Resting HR" } }
    },
    {
      "id": 6,
      "title": "Weight Trend",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 10 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [
        {
          "rawSql": "SELECT measured_at AS time, weight_kg AS \"Weight\" FROM body_metrics WHERE weight_kg IS NOT NULL ORDER BY measured_at",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT measured_at AS time, ROUND(AVG(weight_kg) OVER (ORDER BY measured_at ROWS BETWEEN 6 PRECEDING AND CURRENT ROW)::numeric, 2) AS \"7-day Avg\" FROM body_metrics WHERE weight_kg IS NOT NULL ORDER BY measured_at",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "kg" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Weight" },
            "properties": [{ "id": "custom.lineWidth", "value": 1 }, { "id": "custom.fillOpacity", "value": 5 }, { "id": "color", "value": { "fixedColor": "light-blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "7-day Avg" },
            "properties": [{ "id": "custom.lineWidth", "value": 3 }, { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7,
      "title": "Body Fat % Trend",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "rawSql": "SELECT measured_at AS time, body_fat_pct AS \"Body Fat %\" FROM body_metrics WHERE body_fat_pct IS NOT NULL ORDER BY measured_at",
        "format": "time_series",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "fixedColor": "orange", "mode": "fixed" } } }
    },
    {
      "id": 8,
      "title": "Resting HR Trend",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "rawSql": "SELECT date AS time, resting_hr_bpm AS \"Resting HR\" FROM resting_hr_daily ORDER BY date",
        "format": "time_series",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "bpm", "color": { "fixedColor": "red", "mode": "fixed" } } }
    },
    {
      "id": 9,
      "title": "Monthly Weight Progress",
      "type": "table",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [{
        "rawSql": "SELECT TO_CHAR(date_trunc('month', measured_at), 'YYYY-MM') AS \"Month\", ROUND(AVG(weight_kg)::numeric,1) AS \"Avg Weight (kg)\", ROUND(MIN(weight_kg)::numeric,1) AS \"Min\", ROUND(MAX(weight_kg)::numeric,1) AS \"Max\", ROUND(AVG(body_fat_pct)::numeric,1) AS \"Avg Body Fat %\", ROUND(AVG(bmi)::numeric,1) AS \"Avg BMI\" FROM body_metrics WHERE weight_kg IS NOT NULL GROUP BY 1 ORDER BY 1 DESC LIMIT 24",
        "format": "table",
        "refId": "A"
      }],
      "options": { "sortBy": [{ "displayName": "Month", "desc": true }] }
    }
  ]
}
